---
import Layout from '../../layouts/Layout.astro';
import { getPublishedPosts } from '../../lib/queries';

const posts = await getPublishedPosts(20);
---

<Layout
  title="Guides & Resources for NM Nonprofits | NM Nonprofits"
  description="How-to guides, grant writing tips, and resources for New Mexico nonprofits and their funders."
>
  <div class="container-content py-10">
    <h1 class="text-3xl font-serif font-bold mb-2">Guides & How-Tos</h1>
    <p class="text-gray-500 mb-10">Practical resources for New Mexico nonprofits, grant writers, and funders</p>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a href={`/guides/${post.slug}/`} class="card p-0 overflow-hidden group flex flex-col">
            {post.hero_image_url && (
              <img src={post.hero_image_url} alt={post.title}
                class="w-full h-40 object-cover bg-gray-100" loading="lazy" width="400" height="160" />
            )}
            <div class="p-5 flex flex-col gap-2 flex-1">
              <h2 class="font-semibold text-gray-900 group-hover:text-turquoise-700 transition-colors leading-snug">
                {post.title}
              </h2>
              {post.excerpt && (
                <p class="text-sm text-gray-500 line-clamp-2">{post.excerpt}</p>
              )}
              <p class="text-xs text-gray-400 mt-auto">
                {post.author_name}
                {post.published_at && ` · ${new Date(post.published_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`}
              </p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-gray-400 text-center py-20">Guides coming soon.</p>
    )}
  </div>
</Layout>
