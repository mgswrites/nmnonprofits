---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getDb } from '../../lib/db';
import type { Event } from '../../lib/types';

const sql = getDb();
const events = await sql<Event[]>`
  SELECT * FROM events
  WHERE event_date >= CURRENT_DATE
  ORDER BY event_date ASC
  LIMIT 50
`;
---

<Layout
  title="Nonprofit Events & Trainings in New Mexico | NM Nonprofits"
  description="Upcoming nonprofit trainings, convenings, grant deadlines, and webinars in New Mexico."
>
  <div class="container-content py-10">
    <h1 class="text-3xl font-serif font-bold mb-2">Events & Trainings</h1>
    <p class="text-gray-500 mb-10">Upcoming convenings, workshops, and grant deadlines for NM nonprofits</p>

    {events.length > 0 ? (
      <div class="space-y-4 max-w-3xl">
        {events.map((e) => (
          <a href={e.website_url ?? e.registration_url ?? '#'} target="_blank" rel="noopener noreferrer"
            class="card p-5 flex gap-5 items-start group">
            <!-- Date block -->
            <div class="shrink-0 text-center w-14">
              <div class="text-xs font-semibold text-turquoise-700 uppercase">
                {new Date(e.event_date).toLocaleDateString('en-US', { month: 'short' })}
              </div>
              <div class="text-2xl font-bold text-gray-900 leading-none">
                {new Date(e.event_date).getDate()}
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="font-semibold text-gray-900 group-hover:text-turquoise-700 transition-colors leading-snug">
                {e.title}
              </h2>
              <div class="flex flex-wrap gap-3 mt-1 text-xs text-gray-500">
                {e.is_virtual && <span class="badge bg-blue-50 text-blue-700">Virtual</span>}
                {e.event_type && <span class="capitalize">{e.event_type.replace('_', ' ')}</span>}
                {e.is_free !== null && <span>{e.is_free ? 'Free' : e.cost ? `$${e.cost}` : ''}</span>}
              </div>
              {e.description && (
                <p class="text-sm text-gray-500 mt-1 line-clamp-2">{e.description}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-gray-400 text-center py-20">No upcoming events. Check back soon.</p>
    )}
  </div>
</Layout>
