---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import ListingCard from '../../components/listing/ListingCard.astro';
import { getDb } from '../../lib/db';
import { getListingCards } from '../../lib/queries';
import { buildMetaTitle } from '../../lib/utils';
import type { ListingCard as ListingCardType } from '../../lib/types';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const sql = getDb();

const [cityRows, listings] = await Promise.all([
  sql<{ id: number; name: string; slug: string; description: string | null; hero_image_url: string | null; meta_title: string | null; meta_description: string | null; region_code: string | null }[]>`
    SELECT id, name, slug, description, hero_image_url, meta_title, meta_description, region_code
    FROM cities WHERE slug = ${slug} LIMIT 1
  `,
  getListingCards({ citySlug: slug, limit: 200 }),
]);

const city = cityRows[0];
if (!city) return Astro.redirect('/', 302);

const metaTitle = buildMetaTitle(city.meta_title ?? `Nonprofits in ${city.name}, NM | NM Nonprofits`);
const metaDesc  = city.meta_description ?? `Browse nonprofit organizations in ${city.name}, New Mexico. Find local charities, foundations, and community groups.`;

// Region-based fallback images so every city doesn't show the Albuquerque balloon
const regionFallback: Record<string, string> = {
  albuquerque_metro: '/images/cities/albuquerque.jpg',
  northern_nm:       '/images/cities/taos.jpg',
  southern_nm:       '/images/cities/las-cruces.jpg',
  four_corners:      '/images/cities/gallup.jpg',
  eastern_nm:        '/images/cities/las-vegas-olos.jpg',
  statewide:         '/images/cities/santa-fe.jpg',
};
const heroImg = city.hero_image_url
  ?? regionFallback[city.region_code ?? '']
  ?? '/images/cities/silver-city.jpg';
---

<Layout title={metaTitle} description={metaDesc}>
  <!-- Hero -->
  <div class="relative h-56 md:h-72 overflow-hidden">
    <img
      src={heroImg}
      alt={city.name}
      class="w-full h-full object-cover"
      width="1200"
      height="400"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent" />
    <div class="absolute bottom-0 left-0 right-0 container-content pb-8">
      <nav class="text-xs text-white/60 flex gap-1.5 items-center mb-2">
        <a href="/" class="hover:text-white">Home</a>
        <span>/</span>
        <span class="text-white">{city.name}</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-serif font-bold text-white">
        Nonprofits in {city.name}, NM
      </h1>
    </div>
  </div>

  <div class="container-content py-12">
    <div class="max-w-3xl mb-12">
      <!-- City description -->
      {city.description ? (
        <div class="prose prose-gray max-w-none text-gray-700 leading-relaxed">
          {city.description.split('\n\n').map((p: string) => (
            <p>{p.trim()}</p>
          ))}
        </div>
      ) : (
        <p class="text-gray-500 italic">No city description yet.</p>
      )}
    </div>

    <!-- Listings -->
    <div>
      <h2 class="text-2xl font-serif font-semibold text-gray-900 mb-6">
        {listings.length} {listings.length === 1 ? 'Organization' : 'Organizations'} in {city.name}
      </h2>
      {listings.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {listings.map((l: ListingCardType) => <ListingCard listing={l} />)}
        </div>
      ) : (
        <p class="text-gray-400 text-sm">No listings yet for this city.</p>
      )}
    </div>
  </div>
</Layout>
