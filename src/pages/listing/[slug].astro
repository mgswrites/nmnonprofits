---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getListingBySlug, getRelatedListings } from '../../lib/queries';
import ListingCard from '../../components/listing/ListingCard.astro';
import { getDb } from '../../lib/db';
import { orgTypeLabel, regionLabel, formatCurrency, buildMetaTitle } from '../../lib/utils';
import type { Sector, Listing } from '../../lib/types';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/nonprofits/');

const listing = await getListingBySlug(slug);
if (!listing) return Astro.redirect('/nonprofits/', 301);

// Fetch sectors for this listing
const sql = getDb();
const sectors: Sector[] = (await sql`
  SELECT s.* FROM sectors s
  JOIN listing_sectors ls ON ls.sector_id = s.id
  WHERE ls.listing_id = ${listing.id}
  ORDER BY ls.is_primary DESC, s.name
`) as Sector[];

const related = await getRelatedListings({ listingId: listing.id, cityName: listing.city_name, regionCode: listing.region_code });

const relatedHeading = listing.region_code
  ? `Other nonprofits in ${regionLabel(listing.region_code)}`
  : 'Other nonprofits in New Mexico';

// Auto-generated context paragraph from available data fields
function buildContextParagraph(l: Listing, sects: Sector[]): string {
  const type = orgTypeLabel(l.org_type);
  const location = l.serves_statewide
    ? 'New Mexico'
    : [l.city_name, l.region_code ? regionLabel(l.region_code) : null].filter(Boolean).join(', ') || 'New Mexico';
  const primarySector = sects[0]?.name?.toLowerCase();
  const parts: string[] = [];

  let opening = `${l.name} is a ${type} based in ${location}`;
  if (primarySector) opening += `, with a focus on ${primarySector}`;
  parts.push(opening + '.');

  if (l.year_founded && l.annual_revenue) {
    parts.push(`Founded in ${l.year_founded}, the organization reports annual revenues of ${formatCurrency(l.annual_revenue)}.`);
  } else if (l.year_founded) {
    parts.push(`The organization was founded in ${l.year_founded}.`);
  } else if (l.annual_revenue) {
    parts.push(`The organization reports annual revenues of ${formatCurrency(l.annual_revenue)}.`);
  }

  if (l.ein) {
    const verified = l.is_verified || l.irs_verified;
    parts.push(`${l.name} is a federally recognized tax-exempt organization (EIN: ${l.ein})${verified ? ', verified against IRS records' : ''}.`);
  }

  if (sects.length > 1) {
    const others = sects.slice(1).map(s => s.name.toLowerCase()).join(' and ');
    parts.push(`Beyond ${primarySector || 'its primary focus'}, the organization also works in ${others}.`);
  }

  if (l.serves_statewide) {
    parts.push(`${l.name} provides services across the entire state of New Mexico.`);
  } else if (l.city_name && l.region_code) {
    parts.push(`The organization primarily serves the ${l.city_name} area and surrounding ${regionLabel(l.region_code)} communities.`);
  }

  return parts.join(' ');
}

const contextParagraph = buildContextParagraph(listing, sectors);

// FAQ data + schema
// Mission is already displayed in the hero — keep it in schema only, not visible FAQ
interface FAQ { q: string; a: string }
const schemaFaqs: FAQ[] = [];
if (listing.mission) {
  schemaFaqs.push({ q: `What does ${listing.name} do?`, a: listing.mission });
}
const faqs: FAQ[] = []; // visible FAQ — excludes mission to avoid duplicate
const locStr = listing.serves_statewide
  ? 'across New Mexico'
  : listing.city_name
    ? `in ${listing.city_name}${listing.region_code ? ', ' + regionLabel(listing.region_code) : ''}, New Mexico`
    : 'in New Mexico';
faqs.push({ q: `Where does ${listing.name} operate?`, a: `${listing.name} operates ${locStr}.` });
if (listing.year_founded) {
  faqs.push({ q: `When was ${listing.name} founded?`, a: `${listing.name} was founded in ${listing.year_founded}.` });
}
if (listing.ein) {
  faqs.push({
    q: `Is ${listing.name} a registered nonprofit?`,
    a: `${listing.name} is a federally recognized tax-exempt organization registered with the IRS under EIN ${listing.ein}.`,
  });
}
if (listing.website_url) {
  faqs.push({
    q: `How can I learn more about ${listing.name}?`,
    a: `Visit ${listing.name} online at ${listing.website_url} for information about programs, services, and ways to get involved.`,
  });
}

const allSchemaFaqs = [...schemaFaqs, ...faqs];
const faqSchema = allSchemaFaqs.length >= 2 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allSchemaFaqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

function truncateAtWord(text: string, max = 155): string {
  if (text.length <= max) return text;
  return text.slice(0, max).replace(/\s+\S*$/, '') + '…';
}

const metaTitle = buildMetaTitle(listing.meta_title ?? `${listing.name} | New Mexico Nonprofit`);
const rawDesc   = listing.meta_description ?? listing.mission ?? `${listing.name} is a nonprofit organization in New Mexico.`;
const metaDesc  = truncateAtWord(rawDesc);

// Schema.org NGO markup
const schema = {
  "@context": "https://schema.org",
  "@type": ["NGO", "Organization"],
  "name": listing.name,
  "url": listing.website_url,
  "description": listing.mission,
  "foundingDate": listing.year_founded?.toString(),
  "address": listing.city_name ? {
    "@type": "PostalAddress",
    "addressLocality": listing.city_name,
    "addressRegion": "NM",
    "addressCountry": "US",
  } : undefined,
  "telephone": listing.phone,
  "email": listing.email,
};
---

<Layout title={metaTitle} description={metaDesc} noIndex={!listing.mission}>
  <script is:inline type="application/ld+json" slot="schema" set:html={JSON.stringify(schema)} />
  {faqSchema && <script is:inline type="application/ld+json" slot="schema" set:html={JSON.stringify(faqSchema)} />}

  <!-- Breadcrumb -->
  <nav class="container-content py-3 text-xs text-gray-400 flex gap-1.5 items-center">
    <a href="/" class="hover:text-gray-600">Home</a>
    <span>/</span>
    <a href="/nonprofits/" class="hover:text-gray-600">Nonprofits</a>
    {sectors[0] && (
      <>
        <span>/</span>
        <a href={`/sectors/${sectors[0].slug}/`} class="hover:text-gray-600">{sectors[0].name}</a>
      </>
    )}
    <span>/</span>
    <span class="text-gray-600 truncate max-w-[200px]">{listing.name}</span>
  </nav>

  <article class="container-content pb-16">
    <!-- Hero / header -->
    <div class="flex flex-col md:flex-row gap-6 mb-10 items-start">
      {listing.logo_url && (
        <img src={listing.logo_url} alt={`${listing.name} logo`} width="96" height="96"
          class="w-24 h-24 rounded-xl object-contain bg-gray-50 border border-gray-100 shrink-0" />
      )}

      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap gap-2 mb-2">
          <span class={`badge badge-tier-${listing.tier}`}>{listing.tier}</span>
          {listing.is_verified && (
            <span class="badge bg-turquoise-50 text-turquoise-700">IRS Verified</span>
          )}
          <span class="badge bg-gray-100 text-gray-600">{orgTypeLabel(listing.org_type)}</span>
        </div>
        <h1 class="text-3xl font-serif font-bold text-gray-900 mb-2">{listing.name}</h1>
        {listing.city_name && listing.region_code && (
          <p class="text-gray-500 text-sm">
            {listing.city_name}, {regionLabel(listing.region_code)}
          </p>
        )}
        {listing.mission && (
          <p class="mt-3 text-gray-700 leading-relaxed max-w-2xl">{listing.mission}</p>
        )}
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2 space-y-8">
        {listing.full_description && listing.full_description.trim() !== (listing.mission ?? '').trim() && (
          <section>
            <h2 class="text-xl font-serif font-semibold mb-3">About</h2>
            <div class="prose prose-sm max-w-none text-gray-700">
              {listing.full_description.split('\n\n').map((p: string) => (
                <p>{p.trim()}</p>
              ))}
            </div>
          </section>
        )}

        {sectors.length > 0 && (
          <section>
            <h2 class="text-xl font-serif font-semibold mb-3">Issue Areas</h2>
            <div class="flex flex-wrap gap-2">
              {sectors.map((s) => (
                <a href={`/sectors/${s.slug}/`} class="badge bg-turquoise-50 text-turquoise-800 hover:bg-turquoise-100 transition-colors">
                  {s.name}
                </a>
              ))}
            </div>
          </section>
        )}

        <section>
          <h2 class="text-xl font-serif font-semibold mb-3">About {listing.name}</h2>
          <p class="text-gray-700 leading-relaxed">{contextParagraph}</p>
        </section>

        {faqs.length >= 2 && (
          <section>
            <h2 class="text-xl font-serif font-semibold mb-4">Frequently Asked Questions</h2>
            <dl class="space-y-5">
              {faqs.map((f) => (
                <div>
                  <dt class="font-semibold text-gray-900 mb-1">{f.q}</dt>
                  <dd class="text-gray-600 text-sm leading-relaxed">{f.a}</dd>
                </div>
              ))}
            </dl>
          </section>
        )}
      </div>

      <!-- Sidebar: contact + details -->
      <aside class="space-y-6">
        {(listing.website_url || listing.phone || listing.email) && (
          <div class="card p-5 space-y-3">
            <h3 class="font-semibold text-gray-800 text-sm">Contact</h3>
            {listing.website_url && (
              <a href={listing.website_url} target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 text-sm text-turquoise-700 hover:underline break-all">
                {listing.website_url.replace(/^https?:\/\//, '')}
              </a>
            )}
            {listing.phone && (
              <p class="text-sm text-gray-600">{listing.phone}</p>
            )}
            {listing.email && (
              <a href={`mailto:${listing.email}`} class="text-sm text-turquoise-700 hover:underline break-all">
                {listing.email}
              </a>
            )}
            {listing.executive_director && (
              <p class="text-sm text-gray-600">
                <span class="font-medium">Executive Director:</span> {listing.executive_director}
              </p>
            )}
          </div>
        )}

        <!-- Financial transparency -->
        {(listing.annual_revenue || listing.form_990_url || listing.ein) && (
          <div class="card p-5 space-y-2">
            <h3 class="font-semibold text-gray-800 text-sm">Organization Details</h3>
            {listing.annual_revenue && (
              <p class="text-sm text-gray-600">
                <span class="font-medium">Annual Revenue:</span> {formatCurrency(listing.annual_revenue)}
              </p>
            )}
            {listing.ein && (
              <p class="text-sm text-gray-600">
                <span class="font-medium">EIN:</span> {listing.ein}
              </p>
            )}
            {listing.form_990_url && (
              <a href={listing.form_990_url} target="_blank" rel="noopener noreferrer"
                class="text-sm text-turquoise-700 hover:underline">
                View Form 990 →
              </a>
            )}
            {listing.ein && (
              <a href={`https://projects.propublica.org/nonprofits/organizations/${listing.ein.replace(/-/g, '')}`}
                target="_blank" rel="noopener noreferrer"
                class="text-sm text-turquoise-700 hover:underline block">
                IRS filings on ProPublica →
              </a>
            )}
          </div>
        )}

        {listing.year_founded && (
          <div class="card p-5">
            <p class="text-sm text-gray-600">
              <span class="font-medium">Founded:</span> {listing.year_founded}
            </p>
          </div>
        )}

        {!listing.website_url && (
          <div class="rounded-xl border border-turquoise-200 bg-turquoise-50 p-5">
            <p class="text-sm font-semibold text-turquoise-900 mb-1">Is this your organization?</p>
            <p class="text-xs text-turquoise-700 mb-4 leading-relaxed">
              Claim this listing to add your website, mission, contact info, and logo.
            </p>
            <a
              href={`/submit/?name=${encodeURIComponent(listing.name)}&claim=${listing.slug}`}
              class="block w-full text-center text-sm font-semibold bg-turquoise-700 hover:bg-turquoise-800 text-white rounded-lg py-2 px-4 transition-colors"
            >
              Claim this listing
            </a>
          </div>
        )}

        <div class="card p-5 space-y-2">
          <h3 class="font-semibold text-gray-800 text-sm mb-3">Explore New Mexico</h3>
          {sectors[0] && (
            <a href={`/sectors/${sectors[0].slug}/`} class="text-sm text-turquoise-700 hover:underline block">
              {sectors[0].name} nonprofits in NM →
            </a>
          )}
          {listing.region_code && (
            <a href={`/regions/${listing.region_code.replace(/_/g, '-')}/`} class="text-sm text-turquoise-700 hover:underline block">
              Nonprofits in {regionLabel(listing.region_code)} →
            </a>
          )}
          <a href="/grants/" class="text-sm text-turquoise-700 hover:underline block">
            Open grants in New Mexico →
          </a>
          <a href="/guides/" class="text-sm text-turquoise-700 hover:underline block">
            Nonprofit guides &amp; resources →
          </a>
        </div>
      </aside>
    </div>
  </article>

  {related.length > 0 && (
    <section class="bg-gray-50 border-t border-gray-100 py-12">
      <div class="container-content">
        <h2 class="text-xl font-serif font-semibold text-gray-900 mb-6">
          {relatedHeading}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {related.map((r) => <ListingCard listing={r} />)}
        </div>
        {listing.city_name && (
          <div class="mt-6">
            <a href={`/nonprofits/?region=${listing.region_code}`} class="text-sm text-turquoise-700 hover:underline">
              View all nonprofits in this region &rarr;
            </a>
          </div>
        )}
      </div>
    </section>
  )}
</Layout>
