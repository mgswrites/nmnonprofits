---
import Layout from '../../layouts/Layout.astro';
import { getSectorSummaries } from '../../lib/queries';

const sectors = await getSectorSummaries();

const sectorImg: Record<string, string> = {
  'animal-welfare':           '/images/sectors/animal-welfare.jpg',
  'arts-culture':             '/images/sectors/arts-culture.jpg',
  'civic-engagement':         '/images/sectors/civic-engagement.jpg',
  'economic-development':     '/images/sectors/economic-development.jpg',
  'education-youth':          '/images/sectors/education-youth.jpg',
  'environment-conservation': '/images/sectors/environment-conservation.jpg',
  'food-agriculture':         '/images/sectors/food-agriculture.jpg',
  'health-human-services':    '/images/sectors/health-human-services.jpg',
  'housing-homelessness':     '/images/sectors/housing-homelessness.jpg',
  'immigration-refugee':      '/images/sectors/immigration-refugee.jpg',
  'indigenous-communities':   '/images/sectors/indigenous-communities.jpg',
  'substance-use-recovery':   '/images/sectors/substance-use-recovery.jpg',
};
---

<Layout
  title="New Mexico Nonprofit Sectors | NM Nonprofits"
  description="Browse New Mexico nonprofits and funders by issue area: arts, education, health, housing, environment, and more."
>
  <div class="container-content py-10">
    <h1 class="text-3xl font-serif font-bold mb-2">Issue Areas</h1>
    <p class="text-gray-500 mb-10">Browse New Mexico's nonprofit ecosystem by cause area</p>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {sectors.map((s) => (
        <div class="relative rounded-xl overflow-hidden bg-white border border-gray-100 hover:border-turquoise-200 hover:shadow-md transition-all group">
          <!-- full-cover card link -->
          <a href={`/sectors/${s.slug}/`} class="absolute inset-0 z-0" aria-label={s.name}></a>

          <div class="h-36 overflow-hidden">
            <img
              src={sectorImg[s.slug] ?? '/images/sectors/environment-conservation.jpg'}
              alt={s.name}
              width="400"
              height="288"
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-4">
            <h2 class="font-semibold text-gray-900 group-hover:text-turquoise-700 transition-colors leading-snug">
              {s.name}
            </h2>
            <div class="relative z-10 flex flex-wrap gap-3 text-xs text-gray-400 mt-1.5">
              <span>{s.org_count} nonprofits</span>
              {s.active_grant_count > 0 && (
                <a href={`/grants/?sector=${s.slug}`}
                  class="text-turquoise-600 font-medium hover:underline">
                  {s.active_grant_count} open grants
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
