---
export const prerender = false;

// Redirect /nonprofits/[sector-slug]/ → /sectors/[sector-slug]/
// These URLs were previously generated by the listing detail breadcrumb.
const { sector } = Astro.params;
if (!sector) return Astro.redirect('/nonprofits/', 301);
return Astro.redirect(`/sectors/${sector}/`, 301);
---
