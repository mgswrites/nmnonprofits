---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Submission Received | NM Nonprofits"
  description="Your organization submission has been received."
  noIndex={true}
>
  <div class="container-content py-24 max-w-lg text-center">
    <div class="text-5xl mb-6">✓</div>
    <h1 class="text-3xl font-serif font-bold mb-3">Submission received!</h1>
    <p class="text-gray-600 mb-8 leading-relaxed">
      Thank you for submitting your organization. Our team will review your listing within 2–3 business days
      and email you when it's approved.
    </p>
    <a href="/" class="btn-primary">Back to home</a>
  </div>
</Layout>
