---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getDb } from '../../../lib/db';

const sql = getDb();
const filter = Astro.url.searchParams.get('status') ?? 'pending';

const submissions = await sql<{
  id: number; name: string; org_type: string; city_name: string; region_code: string;
  website_url: string | null; ein: string | null; mission: string | null;
  submitter_name: string | null; submitter_email: string; submitter_note: string | null;
  logo_url: string | null; sectors: string[]; status: string; created_at: string;
}[]>`
  SELECT * FROM listing_submissions
  WHERE status = ${filter}
  ORDER BY created_at DESC
  LIMIT 100
`;

const STATUS_TABS = [
  { value: 'pending',  label: 'Pending' },
  { value: 'approved', label: 'Approved' },
  { value: 'rejected', label: 'Rejected' },
];
---

<AdminLayout title="Org Submissions">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-serif font-bold text-gray-900">Org Submissions</h1>
    <div class="flex gap-2">
      {STATUS_TABS.map(t => (
        <a href={`/admin/submissions/?status=${t.value}`}
          class={`px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${
            filter === t.value
              ? 'bg-turquoise-700 text-white'
              : 'bg-white border border-gray-200 text-gray-600 hover:border-turquoise-300'
          }`}>
          {t.label}
        </a>
      ))}
    </div>
  </div>

  {submissions.length === 0 ? (
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center text-gray-400">
      No {filter} submissions.
    </div>
  ) : (
    <div class="space-y-4">
      {submissions.map(s => (
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <div class="flex items-start justify-between gap-4 flex-wrap">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <h2 class="font-semibold text-gray-900">{s.name}</h2>
                <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full">{s.org_type.replace(/_/g,' ')}</span>
              </div>
              <p class="text-sm text-gray-500">{s.city_name} · {s.region_code.replace(/_/g,' ')}</p>
              {s.ein && <p class="text-xs text-gray-400 mt-0.5">EIN: {s.ein}</p>}
              {s.website_url && (
                <a href={s.website_url} target="_blank" rel="noopener noreferrer"
                  class="text-xs text-turquoise-600 hover:underline mt-0.5 inline-block">{s.website_url}</a>
              )}
              {s.mission && <p class="text-sm text-gray-700 mt-3 leading-relaxed">{s.mission}</p>}
              {s.sectors?.length > 0 && (
                <div class="flex flex-wrap gap-1 mt-2">
                  {s.sectors.map((sec: string) => (
                    <span class="text-xs bg-turquoise-50 text-turquoise-700 px-2 py-0.5 rounded-full">{sec}</span>
                  ))}
                </div>
              )}
              {s.logo_url && (
                <div class="mt-3">
                  <img src={s.logo_url} alt="Submitted logo" class="h-12 w-auto rounded border border-gray-100" />
                </div>
              )}
              <div class="mt-3 pt-3 border-t border-gray-100 text-xs text-gray-400">
                <span>From: {s.submitter_name ? `${s.submitter_name} ` : ''}<a href={`mailto:${s.submitter_email}`} class="text-turquoise-600">{s.submitter_email}</a></span>
                {s.submitter_note && <p class="mt-1 text-gray-500 italic">"{s.submitter_note}"</p>}
                <p class="mt-1">{new Date(s.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' })}</p>
              </div>
            </div>

            {filter === 'pending' && (
              <div class="flex flex-col gap-2 shrink-0">
                <form method="POST" action={`/api/admin/submissions/${s.id}/approve`}>
                  <button class="w-full px-4 py-2 bg-turquoise-700 hover:bg-turquoise-600 text-white text-sm font-medium rounded-lg transition-colors">
                    Approve
                  </button>
                </form>
                <form method="POST" action={`/api/admin/submissions/${s.id}/reject`}>
                  <button class="w-full px-4 py-2 bg-white hover:bg-gray-50 border border-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">
                    Reject
                  </button>
                </form>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  )}
</AdminLayout>
