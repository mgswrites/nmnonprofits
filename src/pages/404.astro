---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | NM Nonprofits"
  description="The page you were looking for doesn't exist."
  noIndex={true}
>
  <div class="container-content py-24 text-center max-w-xl mx-auto">
    <p class="text-turquoise-400 text-6xl font-serif font-bold mb-4">404</p>
    <h1 class="text-2xl font-serif font-semibold text-gray-900 mb-3">Page not found</h1>
    <p class="text-gray-500 mb-8">
      That page doesn't exist or may have moved. Try searching the directory or browsing by issue area.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/nonprofits/" class="btn-primary">Browse nonprofits</a>
      <a href="/sectors/" class="btn-secondary">Browse by issue area</a>
    </div>
    <div class="mt-10 flex flex-wrap justify-center gap-4 text-sm text-gray-400">
      <a href="/" class="hover:text-turquoise-700">Home</a>
      <a href="/funders/" class="hover:text-turquoise-700">Funders</a>
      <a href="/grants/" class="hover:text-turquoise-700">Grants</a>
      <a href="/jobs/" class="hover:text-turquoise-700">Jobs</a>
      <a href="/guides/" class="hover:text-turquoise-700">Guides</a>
      <a href="/submit/" class="hover:text-turquoise-700">Submit your org</a>
    </div>
  </div>
</Layout>
