---
import Layout from '../layouts/Layout.astro';
import ListingCard from '../components/listing/ListingCard.astro';
import GrantCard from '../components/grant/GrantCard.astro';
import { getFeaturedListings, getOpenGrants, getSectorSummaries, getCitiesWithOrgs } from '../lib/queries';

const [featuredListings, openGrants, sectors, cities] = await Promise.all([
  getFeaturedListings(6),
  getOpenGrants(6),
  getSectorSummaries(),
  getCitiesWithOrgs(),
]);

const sectorImages: Record<string, string> = {
  'animal-welfare':           '5Rug51UizG0',
  'arts-culture':             'LGcVVAYPLXo',
  'civic-engagement':         'P8QgGU2y3Ps',
  'economic-development':     'SwJc84JKwxc',
  'education-youth':          'rDowC8HK1BQ',
  'environment-conservation': 'Y3L8ZKU73Gg',
  'food-agriculture':         'jR-9M5C9a2A',
  'health-human-services':    'mYAtldFBSaw',
  'housing-homelessness':     'SqslSHi0NMw',
  'immigration-refugee':      'rj943dUvpWI',
  'indigenous-communities':   '1515168746408-0f924dbb5c39',
  'substance-use-recovery':   'GUqDKefYx5I',
};

const cityImages: Record<string, string> = {
  'albuquerque': 'Y1WzhGASD10',
  'santa-fe':    '3snKY0XMKwg',
  'taos':        'hiurD_9ukfA',
  'las-cruces':  'yB29SGGBMi8',
  'gallup':      'trGP1DdqAlU',
  'silver-city': 'iQUzfZicrZM',
  'las-vegas':   '9-WVTrFrlWI',
};

const u = (id: string) =>
  `https://images.unsplash.com/photo-${id}?w=400&h=224&fit=crop&auto=format&q=80`;

const cityLinks = [
  { label: 'Albuquerque',   href: '/nonprofits/?city=albuquerque' },
  { label: 'Santa Fe',      href: '/nonprofits/?city=santa-fe' },
  { label: 'Las Cruces',    href: '/nonprofits/?city=las-cruces' },
  { label: 'Taos',          href: '/nonprofits/?city=taos' },
  { label: 'Las Vegas, NM', href: '/nonprofits/?city=las-vegas' },
  { label: 'Farmington',    href: '/nonprofits/?city=farmington' },
  { label: 'Roswell',       href: '/nonprofits/?city=roswell' },
  { label: 'Gallup',        href: '/nonprofits/?city=gallup' },
];
---

<Layout
  title="NM Nonprofits — New Mexico Nonprofit & Funder Directory"
  description="Find New Mexico nonprofits, foundations, and open grant opportunities. The definitive directory for the NM social sector."
>
  <!-- Schema: WebSite -->
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "NM Nonprofits",
    "url": "https://nmnonprofits.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://nmnonprofits.com/nonprofits/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-turquoise-900 via-turquoise-800 to-turquoise-700 text-white">
    <div class="container-content py-20 md:py-28 text-center">
      <p class="text-turquoise-300 text-sm font-semibold uppercase tracking-widest mb-4">
        New Mexico's Nonprofit Ecosystem
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 leading-tight">
        Find the organizations<br class="hidden sm:block" /> shaping New Mexico
      </h1>
      <p class="text-turquoise-100 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">
        Browse 7,000+ nonprofits, foundations, and funders. Discover open grant opportunities. Connect with the New Mexico social sector.
      </p>

      <!-- Search bar -->
      <form action="/nonprofits/" method="get" class="max-w-xl mx-auto flex gap-2">
        <input
          type="search"
          name="q"
          placeholder="Search nonprofits, funders, or causes…"
          class="flex-1 px-4 py-3 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-turquoise-400"
          aria-label="Search nonprofits"
        />
        <button type="submit" class="btn-primary bg-zia-600 hover:bg-zia-700 whitespace-nowrap">
          Search
        </button>
      </form>

      <!-- City quick-links -->
      <div class="mt-6 flex flex-wrap justify-center gap-2">
        {cityLinks.map((c) => (
          <a href={c.href} class="text-xs text-turquoise-200 hover:text-white bg-white/10 hover:bg-white/20 px-3 py-1.5 rounded-full transition-colors">
            {c.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sector grid -->
  <section class="py-16 bg-gray-50">
    <div class="container-content">
      <h2 class="section-header text-center">Browse by Issue Area</h2>
      <p class="text-center text-gray-500 text-sm mb-10">Explore nonprofits and funders by the causes they serve</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {sectors.map((s) => (
          <a
            href={`/nonprofits/${s.slug}/`}
            class="rounded-xl overflow-hidden bg-white border border-gray-100 hover:border-turquoise-200 hover:shadow-md transition-all group"
          >
            <div class="h-28 overflow-hidden">
              <img
                src={u(sectorImages[s.slug] ?? 'Y3L8ZKU73Gg')}
                alt={s.name}
                width="400"
                height="224"
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="p-3 text-center">
              <span class="text-sm font-semibold text-gray-800 group-hover:text-turquoise-700 transition-colors leading-snug block">
                {s.name}
              </span>
              <span class="text-xs text-gray-400 mt-1 block">{s.org_count} orgs</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Browse by City -->
  <section class="py-16">
    <div class="container-content">
      <h2 class="section-header text-center">Browse by City</h2>
      <p class="text-center text-gray-500 text-sm mb-10">Find nonprofits serving your community</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {cities.map((c) => (
          <a
            href={`/nonprofits/?city=${c.slug}`}
            class="rounded-xl overflow-hidden bg-white border border-gray-100 hover:border-turquoise-200 hover:shadow-md transition-all group"
          >
            <div class="h-28 overflow-hidden">
              <img
                src={u(cityImages[c.slug] ?? 'iQUzfZicrZM')}
                alt={c.name}
                width="400"
                height="224"
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="p-3 text-center">
              <span class="text-sm font-semibold text-gray-800 group-hover:text-turquoise-700 transition-colors leading-snug block">
                {c.name}
              </span>
              <span class="text-xs text-gray-400 mt-1 block">{c.org_count} orgs</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured nonprofits -->
  {featuredListings.length > 0 && (
    <section class="py-16">
      <div class="container-content">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="section-header">Featured Nonprofits</h2>
            <p class="text-gray-500 text-sm">Organizations making a difference across New Mexico</p>
          </div>
          <a href="/nonprofits/" class="btn-secondary text-sm">View all</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {featuredListings.map((l) => <ListingCard listing={l} />)}
        </div>
      </div>
    </section>
  )}

  <!-- Open grants -->
  {openGrants.length > 0 && (
    <section class="py-16 bg-gray-50">
      <div class="container-content">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="section-header">Open Grant Opportunities</h2>
            <p class="text-gray-500 text-sm">Active funding available for NM nonprofits</p>
          </div>
          <a href="/grants/" class="btn-secondary text-sm">View all grants</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {openGrants.map((g) => <GrantCard grant={g} />)}
        </div>
      </div>
    </section>
  )}

  <!-- Submit CTA -->
  <section class="py-20">
    <div class="container-content">
      <div class="bg-turquoise-800 rounded-2xl p-8 md:p-12 text-center text-white">
        <h2 class="text-3xl font-serif font-bold mb-3">Is your organization listed?</h2>
        <p class="text-turquoise-200 mb-8 max-w-xl mx-auto">
          Add your nonprofit or foundation to the directory. Basic listings are free. Premium tiers offer enhanced visibility and grant-matching alerts.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/submit/" class="btn-primary bg-zia-600 hover:bg-zia-500">Submit Your Organization</a>
          <a href="/guides/listing-tiers/" class="btn-secondary border-turquoise-600 bg-transparent text-white hover:bg-white/10">See pricing</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
