---
import type { JobCard } from '../../lib/types';

interface Props {
  job: JobCard;
}

const { job } = Astro.props;

const JOB_TYPE_LABELS: Record<string, string> = {
  full_time:  'Full-time',
  part_time:  'Part-time',
  contract:   'Contract',
  volunteer:  'Volunteer',
  internship: 'Internship',
};

const JOB_TYPE_COLORS: Record<string, string> = {
  full_time:  'bg-turquoise-100 text-turquoise-800',
  part_time:  'bg-blue-100 text-blue-800',
  contract:   'bg-purple-100 text-purple-800',
  volunteer:  'bg-green-100 text-green-800',
  internship: 'bg-zia-100 text-zia-800',
};

function formatSalary(min: number | null, max: number | null, note: string | null): string {
  const fmt = (n: number) => '$' + n.toLocaleString('en-US');
  if (min && max) return `${fmt(min)} – ${fmt(max)}`;
  if (min) return `${fmt(min)}+`;
  if (max) return `Up to ${fmt(max)}`;
  return note ?? '';
}

function daysAgo(dateStr: string): string {
  const days = Math.floor((Date.now() - new Date(dateStr).getTime()) / 86400000);
  if (days === 0) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days} days ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  return `${Math.floor(days / 30)}mo ago`;
}

const salary = formatSalary(job.salary_min, job.salary_max, job.salary_note);
const typeColor = JOB_TYPE_COLORS[job.job_type] ?? 'bg-gray-100 text-gray-700';
---

<a
  href={`/jobs/${job.slug}/`}
  class="card flex flex-col p-5 gap-3 group"
  aria-label={job.title}
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h3 class="font-semibold text-gray-900 group-hover:text-turquoise-700 transition-colors leading-snug text-sm line-clamp-2">
        {job.title}
      </h3>
      <p class="text-xs text-gray-500 mt-0.5">
        {job.listing_slug
          ? <a href={`/listing/${job.listing_slug}/`} class="hover:text-turquoise-700 hover:underline" onclick="event.stopPropagation()">{job.org_name}</a>
          : job.org_name
        }
      </p>
    </div>
    <span class={`badge shrink-0 ${typeColor}`}>
      {JOB_TYPE_LABELS[job.job_type] ?? job.job_type}
    </span>
  </div>

  <div class="flex items-center gap-3 text-xs text-gray-400 flex-wrap">
    {job.city_name && (
      <span class="flex items-center gap-1">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        {job.city_name}, NM
      </span>
    )}
    {salary && (
      <span class="text-turquoise-700 font-medium">{salary}</span>
    )}
    <span class="ml-auto">{daysAgo(job.created_at)}</span>
  </div>

  {job.deadline && (
    <p class="text-xs text-gray-400 border-t border-gray-50 pt-2">
      Apply by {new Date(job.deadline).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
    </p>
  )}
</a>
