---
const year = new Date().getFullYear();

const columns = [
  {
    heading: 'Directory',
    links: [
      { href: '/nonprofits/',   label: 'All Nonprofits' },
      { href: '/funders/',      label: 'Funders & Foundations' },
      { href: '/grants/',       label: 'Grant Opportunities' },
      { href: '/sectors/',      label: 'Issue Areas' },
      { href: '/jobs/',         label: 'Nonprofit Jobs' },
    ],
  },
  {
    heading: 'Regions',
    links: [
      { href: '/regions/albuquerque-metro',    label: 'Albuquerque Metro' },
      { href: '/regions/northern-new-mexico',  label: 'Northern NM' },
      { href: '/regions/southern-new-mexico',  label: 'Southern NM' },
      { href: '/regions/four-corners',         label: 'Four Corners' },
      { href: '/regions/eastern-new-mexico',   label: 'Eastern NM' },
    ],
  },
  {
    heading: 'Resources',
    links: [
      { href: '/guides/',       label: 'Guides & How-Tos' },
      { href: '/events/',       label: 'Events & Trainings' },
      { href: '/submit/',       label: 'Submit Your Org' },
      { href: '/about/',        label: 'About' },
      { href: '/contact/',      label: 'Contact' },
    ],
  },
];
---

<footer class="border-t border-gray-100 bg-gray-50 mt-20">
  <div class="container-content py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="font-serif font-bold text-lg text-turquoise-800">NM Nonprofits</a>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed max-w-xs">
          The definitive directory of New Mexico nonprofits, foundations, and grant opportunities.
        </p>
      </div>

      <!-- Nav columns -->
      {columns.map((col) => (
        <div>
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">
            {col.heading}
          </h3>
          <ul class="space-y-2">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-600 hover:text-turquoise-700 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Newsletter signup -->
    <div class="mt-10 pt-8 border-t border-gray-200">
      <div class="max-w-md">
        <h3 class="text-sm font-semibold text-gray-700 mb-1">Stay in the loop</h3>
        <p class="text-xs text-gray-500 mb-3">New grants, jobs, and NM nonprofit news — delivered occasionally, no spam.</p>
        <form id="newsletter-form" class="flex gap-2">
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            class="flex-1 text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-turquoise-500"
          />
          <button type="submit" class="btn-primary text-sm whitespace-nowrap shrink-0">Subscribe</button>
        </form>
        <p id="newsletter-msg" class="text-xs text-turquoise-700 mt-2 hidden">You're subscribed. Thanks!</p>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-200 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-400">&copy; {year} NM Nonprofits. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/about/"   class="text-xs text-gray-400 hover:text-gray-600">About</a>
        <a href="/contact/" class="text-xs text-gray-400 hover:text-gray-600">Contact</a>
        <a href="/privacy/" class="text-xs text-gray-400 hover:text-gray-600">Privacy</a>
      </div>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const msg  = document.getElementById('newsletter-msg');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form!);
    const res = await fetch('/api/newsletter', { method: 'POST', body: fd });
    if (res.ok) {
      form!.classList.add('hidden');
      msg?.classList.remove('hidden');
    }
  });
</script>
